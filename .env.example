# Copy to `.env` in the project root (same folder as `README.md`).
# Never commit `.env` — it is listed in `.gitignore`.

# Gmail: use an App Password (Google Account → Security → App passwords).
ALERT_EMAIL=
ALERT_PASSWORD=
RECIPIENT_EMAIL=
# Multiple recipients: comma-separated, e.g. staff1@college.edu,staff2@college.edu
# Or use the app Settings tab (saves to data/email_recipients.json and overrides this).

# Optional overrides
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Legacy variable names (still supported if ALERT_* not set)
# SMTP_USER=
# SMTP_PASS=
# STAFF_EMAIL=

# Prediction history (optional). If MongoDB is unreachable, SQLite is used at data/predictions.db
# MONGODB_URI=mongodb://localhost:27017/
# USE_MONGODB=0

# Frontend (optional): put in `frontend/.env` so Vite loads it. When unset during `npm run dev`,
# requests go to `/api` and Vite proxies to Flask on port 5000 (see frontend/vite.config.js).
# For a production build against a remote API, set e.g. VITE_API_URL=https://your-api.example.com
# VITE_API_URL=http://127.0.0.1:5000
