# Copy to `.env` in the project root (same folder as `README.md`).
# Never commit `.env` — it is listed in `.gitignore`.

# Gmail: use an App Password (Google Account → Security → App passwords).
ALERT_EMAIL=
ALERT_PASSWORD=
RECIPIENT_EMAIL=

# Optional overrides
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Legacy variable names (still supported if ALERT_* not set)
# SMTP_USER=
# SMTP_PASS=
# STAFF_EMAIL=
